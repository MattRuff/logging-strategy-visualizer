{
  "name": "logging-strategy-visualizer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && VITE_BUILD_VERSION=$(git rev-parse HEAD) vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "upload-sourcemaps": "datadog-ci sourcemaps upload ./dist/assets --service=logging-workflow --release-version=$(git rev-parse HEAD) --minified-path-prefix=/assets",
    "deploy": "bash scripts/deploy.sh"
  },
  "dependencies": {
    "@datadog/browser-rum": "^6.33.0",
    "@tanstack/react-table": "^8.20.5",
    "@xyflow/react": "^12.3.6",
    "exceljs": "^4.4.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^4.2.1",
    "oidc-client-ts": "^3.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.1.7",
    "react-router-dom": "^7.14.2",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@datadog/datadog-ci": "^5.16.1",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~5.6.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
