# Remote state for the experimental stack.
# CRITICAL: this MUST use a DIFFERENT key (or workspace) from the stable stack at ../../terraform.
# Mixing the two states will let an `apply` here mutate stable resources, defeating the isolation contract.
#
# terraform {
#   backend "s3" {
#     bucket         = "your-org-terraform-state"
#     key            = "logging-strategy/experimental/terraform.tfstate"   # <-- distinct from stable's key
#     region         = "us-east-1"
#     encrypt        = true
#     dynamodb_table = "terraform-locks"
#   }
# }
