# Local dev environment.
# Copy to .env.local (gitignored) and fill from `terraform output`.

VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_COGNITO_DOMAIN=https://logstrat-exp-mruff.auth.us-east-1.amazoncognito.com
VITE_COGNITO_REGION=us-east-1

# In production, /api/* is proxied by CloudFront to API Gateway, so leave this as /api.
# For local dev, point at the API Gateway invoke URL directly.
VITE_API_BASE_URL=https://YOUR_API_ID.execute-api.us-east-1.amazonaws.com/api
